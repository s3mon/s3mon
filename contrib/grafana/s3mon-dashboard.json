{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus / VictoriaMetrics",
      "description": "Any Prometheus-compatible datasource (Prometheus, VictoriaMetrics, Thanos, Cortex, Mimir…)",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "S3 object monitoring via s3mon — shows which bucket/prefix combinations are healthy, missing or erroring.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "icon": "external link",
      "title": "s3mon on GitHub",
      "tooltip": "s3mon source code and documentation",
      "type": "link",
      "url": "https://github.com/s3mon/s3mon"
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 10,
      "title": "Summary",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "red", "index": 0, "text": "MISSING" }, "1": { "color": "green", "index": 1, "text": "OK" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Objects OK",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(s3mon_object_exists{job=~\"$job\"})",
          "legendFormat": "Existing",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Missing Objects",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(1 - s3mon_object_exists{job=~\"$job\"})",
          "legendFormat": "Missing",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "S3 API Errors",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(s3mon_check_error{job=~\"$job\"})",
          "legendFormat": "Errors",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Size Mismatches",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(s3mon_size_mismatch{job=~\"$job\"})",
          "legendFormat": "Size mismatches",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 11,
      "title": "Bucket / Prefix Status",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "filterable": true, "inspect": false },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 80 }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "exists" },
            "properties": [
              { "id": "displayName", "value": "Exists" },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "mappings", "value": [{ "options": { "0": { "color": "red", "index": 0, "text": "✗ MISSING" }, "1": { "color": "green", "index": 1, "text": "✓ OK" } }, "type": "value" }] }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "error" },
            "properties": [
              { "id": "displayName", "value": "API Error" },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "mappings", "value": [{ "options": { "0": { "color": "green", "index": 0, "text": "OK" }, "1": { "color": "red", "index": 1, "text": "ERROR" } }, "type": "value" }] }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "size_mismatch" },
            "properties": [
              { "id": "displayName", "value": "Size Mismatch" },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "mappings", "value": [{ "options": { "0": { "color": "green", "index": 0, "text": "OK" }, "1": { "color": "orange", "index": 1, "text": "TOO SMALL" } }, "type": "value" }] }
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 6 },
      "id": 5,
      "options": { "cellHeight": "sm", "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false }, "showHeader": true, "sortBy": [{ "desc": false, "displayName": "bucket" }] },
      "title": "All Monitored Prefixes",
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true }, "renameByName": { "bucket": "Bucket", "prefix": "Prefix" } } }
      ],
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "s3mon_object_exists{job=~\"$job\",bucket=~\"$bucket\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "exists",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "s3mon_check_error{job=~\"$job\",bucket=~\"$bucket\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "error",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "s3mon_size_mismatch{job=~\"$job\",bucket=~\"$bucket\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "size_mismatch",
          "refId": "C"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "id": 12,
      "title": "Trends",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "axisCenteredZero": false, "axisColorMode": "text", "axisLabel": "", "axisPlacement": "auto", "barAlignment": 0, "drawStyle": "line", "fillOpacity": 10, "gradientMode": "none", "hideFrom": { "legend": false, "tooltip": false, "viz": false }, "lineInterpolation": "stepAfter", "lineWidth": 2, "pointSize": 5, "scaleDistribution": { "type": "linear" }, "showPoints": "never", "spanNulls": false, "stacking": { "group": "A", "mode": "none" }, "thresholdsStyle": { "mode": "off" } },
          "max": 1,
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 80 }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "id": 6,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "title": "Object Exists (by bucket/prefix)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "s3mon_object_exists{job=~\"$job\",bucket=~\"$bucket\"}",
          "legendFormat": "{{bucket}}/{{prefix}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "axisCenteredZero": false, "axisColorMode": "text", "axisLabel": "", "axisPlacement": "auto", "barAlignment": 0, "drawStyle": "line", "fillOpacity": 10, "gradientMode": "none", "hideFrom": { "legend": false, "tooltip": false, "viz": false }, "lineInterpolation": "stepAfter", "lineWidth": 2, "pointSize": 5, "scaleDistribution": { "type": "linear" }, "showPoints": "never", "spanNulls": false, "stacking": { "group": "A", "mode": "none" }, "thresholdsStyle": { "mode": "off" } },
          "max": 1,
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 80 }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "id": 7,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "title": "API Errors & Size Mismatches",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "s3mon_check_error{job=~\"$job\",bucket=~\"$bucket\"}",
          "legendFormat": "error — {{bucket}}/{{prefix}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "s3mon_size_mismatch{job=~\"$job\",bucket=~\"$bucket\"}",
          "legendFormat": "size_mismatch — {{bucket}}/{{prefix}}",
          "refId": "B"
        }
      ]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 36,
  "tags": ["s3", "backup", "monitoring", "s3mon"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Datasource"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(s3mon_object_exists, job)",
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "name": "job",
        "query": { "query": "label_values(s3mon_object_exists, job)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "sort": 1,
        "type": "query",
        "label": "Job"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(s3mon_object_exists{job=~\"$job\"}, bucket)",
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "name": "bucket",
        "query": { "query": "label_values(s3mon_object_exists{job=~\"$job\"}, bucket)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "sort": 1,
        "type": "query",
        "label": "Bucket"
      }
    ]
  },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "s3mon — S3 Object Monitor",
  "uid": "s3mon-dashboard",
  "version": 1
}
